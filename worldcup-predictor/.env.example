# PostgreSQL
DATABASE_URL=postgresql+psycopg2://wcp:wcp@localhost:5432/wcp

# Redis (Celery broker / cache)
REDIS_URL=redis://localhost:6379/0

# Kafka brokers (comma-separated)
KAFKA_BROKERS=localhost:9092

# External data source API keys
API_FOOTBALL_KEY=
ODDS_API_KEY=

# Proxy pool endpoint (returns a usable proxy URL on GET)
PROXY_POOL_URL=

# Logging
LOG_LEVEL=INFO

# Scraper concurrency
SCRAPER_CONCURRENT=8

# Active competitions to ingest (comma-separated "{league_id}:{year}").
# Default = FIFA World Cup 2026.
ACTIVE_COMPETITIONS=1:2026

# --- ML inference API (Phase 2) ---
# Static API key validated by FastAPI middleware. Leave blank to disable auth.
API_KEY=
API_RATE_LIMIT_PER_MIN=100
API_CORS_ORIGINS=*
PREDICTIONS_TODAY_CACHE_TTL=300

# --- Admin console (Phase 5) ---
# Token gating /api/v1/admin/* — empty disables the admin API entirely.
# Operators set a long random hex string; the frontend reads it from
# localStorage['wcp_admin_token'] and sends it as X-Admin-Token.
# Generate with: openssl rand -hex 16
ADMIN_API_TOKEN=

# --- MLflow (Phase 2) ---
MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_DEFAULT_EXPERIMENT=wcp-poisson-baseline
# Which registered model the API + Celery workers load at Production stage.
# Switching this lets us promote a new model class without code changes.
# Options: poisson_v1 (independent Poisson) | dixon_coles_v1 | poisson_glm_v1
ACTIVE_MODEL_NAME=poisson_glm_v1

# --- S3 / MinIO (Phase 3 — share-card storage) ---
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=wcp-minio
S3_SECRET_KEY=wcp-minio-secret
S3_REGION=us-east-1
S3_BUCKET_CARDS=wcp-cards
S3_PUBLIC_BASE_URL=
