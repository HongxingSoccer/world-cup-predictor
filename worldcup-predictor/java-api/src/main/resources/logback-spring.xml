<?xml version="1.0" encoding="UTF-8"?>
<!--
  Profile-gated logback config.

  * dev profile  → human-readable single-line pattern (easy to scan in
                   `docker compose logs java-api`).
  * everything else (incl. production) → JSON via logstash-logback-encoder,
                   so CloudWatch / Loki / Datadog can index by field.

  Both encoders include the canonical request_id slot via MDC[%X{requestId}];
  the JwtAuthFilter + AccessLog handlers stash it there.
-->
<configuration>

    <springProperty scope="context" name="appName" source="spring.application.name" defaultValue="wcp-java-api"/>
    <springProperty scope="context" name="appProfile" source="spring.profiles.active" defaultValue="default"/>

    <!-- ============================== -->
    <!-- DEV: pattern encoder (legible) -->
    <!-- ============================== -->
    <springProfile name="dev">
        <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
            <encoder>
                <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} %-5level [%thread] %logger{35} - %msg%n</pattern>
            </encoder>
        </appender>

        <root level="INFO">
            <appender-ref ref="CONSOLE"/>
        </root>

        <logger name="org.springframework.web" level="DEBUG"/>
        <logger name="com.wcp" level="DEBUG"/>
    </springProfile>

    <!-- ===================================== -->
    <!-- DEFAULT / prod / staging: JSON encoder -->
    <!-- ===================================== -->
    <springProfile name="!dev">
        <appender name="JSON" class="ch.qos.logback.core.ConsoleAppender">
            <encoder class="net.logstash.logback.encoder.LogstashEncoder">
                <!-- Mirror the Python structlog shape so the two services
                     show up uniformly in any log search backend. -->
                <fieldNames>
                    <timestamp>timestamp</timestamp>
                    <message>message</message>
                    <thread>thread</thread>
                    <logger>logger</logger>
                    <level>level</level>
                </fieldNames>
                <includeMdcKeyName>requestId</includeMdcKeyName>
                <includeMdcKeyName>userUuid</includeMdcKeyName>
                <customFields>{"service":"${appName}","profile":"${appProfile}"}</customFields>
            </encoder>
        </appender>

        <root level="INFO">
            <appender-ref ref="JSON"/>
        </root>

        <logger name="com.wcp" level="INFO"/>
    </springProfile>
</configuration>
